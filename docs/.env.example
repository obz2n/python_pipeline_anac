# ============================================================
# Configurações de banco de dados
# ============================================================
# dotenv
USER=seu_usuario
PASSWORD=seu_password_aqui
HOST=localhost # ou IP
PORT=sua_porta
DATABASE=seu_db
SCHEMA=seu_schema
DB_DIALECT=postgresql

# Postgres
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=Obzen@seu_password_aqui!
POSTGRES_DB=seu_db
POSTGRES_PORT=sua_porta

# ============================================================
# Observações
# ============================================================
# 1. Copie este arquivo para .env e preencha com seus dados
# 2. NUNCA commite o arquivo .env com dados reais
# 3. O arquivo .env é ignorado pelo git (verifique .gitignore)
