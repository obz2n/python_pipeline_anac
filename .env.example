# ============================================================
# Configurações de banco de dados
# ============================================================
#
# PostgreSQL (usar credenciais existentes)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PASSWORD_ENCODED=
POSTGRES_DB=
POSTGRES_PORT=

# dbt e scripts Python (mesmo banco PostgreSQL acima)
DB_USER=
PASSWORD=
HOST=
PORT=
DATABASE=
SCHEMA=
DB_DIALECT=

# Airflow (opcional, gera automaticamente se deixado em branco)
AIRFLOW_FERNET_KEY=
AIRFLOW_UID=50000


# ============================================================
# Observações
# ============================================================
# 1. Copie este arquivo para .env e preencha com seus dados
# 2. NUNCA commite o arquivo .env com dados reais
# 3. O arquivo .env é ignorado pelo git (verifique .gitignore)
