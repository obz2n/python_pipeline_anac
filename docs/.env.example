# ============================================================
# Configurações de banco de dados
# ============================================================
# dotenv
USER=seu_usuario
PASSWORD=seu_password_aqui
HOST=localhost # ou IP
PORT=sua_porta
DATABASE=seu_db
SCHEMA=seu_schema
DB_DIALECT=postgresql

# Postgres
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=Obzen@seu_password_aqui!
POSTGRES_DB=seu_db
POSTGRES_PORT=sua_porta

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow_dw

# Airflow (opcional, gera automaticamente se deixado em branco)
AIRFLOW_FERNET_KEY=FEqz77TJ0jBQq0Vvu2GhPr_hO0jL_HfhXCZI8K3NWHQ=

